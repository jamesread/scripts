#!/usr/bin/env bash
set -euo pipefail

# fedora-overnight-upgrade
#
# Usage:
#   sudo fedora-overnight-upgrade install
#   sudo fedora-overnight-upgrade install --loop-until <version>
#   sudo fedora-overnight-upgrade run
#   sudo fedora-overnight-upgrade run-loop
#   fedora-overnight-upgrade notify
#
# Install once to enable a daily 03:00 systemd timer. Each run checks whether
# Fedora release n+1 is available; if not, it exits silently with no notification.
# When an upgrade is available, it updates the current system, stages the release
# upgrade, notifies via Apprise, and reboots into the offline upgrade.
#
# Install with --loop-until <version> to enable a boot-time service instead of
# the daily timer. On each boot the service waits five minutes (cancellable),
# then upgrades one Fedora release at a time until the host reaches <version>.
# Status is written to the primary console framebuffer (tty1) and the log file.
#
# Apprise notifications use the apprise CLI and its configured config file
# (e.g. ~/.apprise.yml, or /root/.apprise.yml when run as root). Override with
# APPRISE_CONFIG if needed.
#
# Target release is detected automatically as current Fedora release + 1.

SCRIPT_PATH="$(readlink -f "$0")"
SERVICE_NAME="fedora-overnight-upgrade"
BOOT_SERVICE_NAME="${SERVICE_NAME}-boot"
INSTALL_PATH="/usr/local/sbin/${SERVICE_NAME}"
CONFIG_FILE="/etc/${SERVICE_NAME}.conf"
SCHEDULE="03:00"
GRACE_SECONDS=300
CANCEL_FILE="/run/${SERVICE_NAME}.cancel"

TARGET_RELEASE=""
LOOP_UNTIL=""
LOOP_UNTIL_INSTALL=""
CONSOLE_FD=""

HOST="$(hostname -f 2>/dev/null || hostname)"
LOG_FILE="/var/log/fedora-overnight-upgrade.log"

console_open() {
  if [[ -w /dev/tty1 ]]; then
    exec 3<>/dev/tty1 2>/dev/null || true
    if [[ -e /proc/self/fd/3 ]]; then
      CONSOLE_FD=3
    fi
  fi
}

console_log() {
  local msg="[$(date --iso-8601=seconds)] $*"
  if [[ "${EUID}" -eq 0 ]]; then
    echo "$msg" >>"$LOG_FILE"
  fi
  if [[ -n "$CONSOLE_FD" ]]; then
    echo "$msg" >&"${CONSOLE_FD}"
  elif [[ "${EUID}" -ne 0 ]]; then
    echo "$msg" >&2
  fi
}

log() {
  local msg="$*"
  local line="[$(date --iso-8601=seconds)] $msg"
  if [[ "${EUID}" -eq 0 ]]; then
    echo "$line" | tee -a "$LOG_FILE"
  else
    echo "$line" >&2
  fi
}

send_apprise() {
  local type="$1"
  local title="$2"
  local body="$3"

  if ! command -v apprise >/dev/null 2>&1; then
    return 1
  fi

  local -a cmd=(-n "$type" -t "$title" -b "$body")
  if [[ -n "${APPRISE_CONFIG:-}" ]]; then
    cmd=(-c "$APPRISE_CONFIG" "${cmd[@]}")
  fi

  apprise "${cmd[@]}"
}

notify() {
  local type="$1"
  local title="$2"
  local body="$3"
  local full_title="${HOST}: ${title}"
  local full_body="Host: ${HOST}
${body}"

  if send_apprise "$type" "$full_title" "$full_body" >/dev/null 2>&1; then
    log "Apprise notification sent"
    return 0
  fi

  log "WARNING: failed to send Apprise notification"
  return 1
}

fail() {
  local msg="$1"
  if [[ -n "$CONSOLE_FD" ]]; then
    console_log "ERROR: $msg"
  else
    log "ERROR: $msg"
  fi
  notify "failure" "Fedora upgrade failed" "$msg"
  exit 1
}

usage() {
  cat >&2 <<EOF
Usage:
  sudo $0 install [--loop-until <version>]
  sudo $0 run
  sudo $0 run-loop
  $0 notify

  install [--loop-until <version>]
            Install/update the script and enable systemd automation.
            Without --loop-until: daily ${SCHEDULE} timer (upgrade n+1 when available).
            With --loop-until: boot-time service that upgrades one release per reboot
            until Fedora <version> is reached.
  run       Check for Fedora n+1 upgrade, stage it if available, and reboot
  run-loop  Boot-time loop upgrade (used by the boot systemd service)
  notify    Send a test Apprise notification

  Cancel a pending boot-time upgrade during the ${GRACE_SECONDS}s grace period:
    touch ${CANCEL_FILE}
    systemctl stop ${BOOT_SERVICE_NAME}.service
    Press any key on the primary console (tty1)
EOF
  exit 1
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "Run as root: sudo $0 install" >&2
    exit 1
  fi
}

parse_install_args() {
  LOOP_UNTIL_INSTALL=""
  while (( $# > 0 )); do
    case "$1" in
      --loop-until)
        if (( $# < 2 )); then
          echo "Missing value for --loop-until" >&2
          usage
        fi
        LOOP_UNTIL_INSTALL="$2"
        if [[ ! "$LOOP_UNTIL_INSTALL" =~ ^[0-9]+$ ]]; then
          echo "Invalid --loop-until value: ${LOOP_UNTIL_INSTALL}" >&2
          exit 1
        fi
        shift 2
        ;;
      *)
        echo "Unknown install option: $1" >&2
        usage
        ;;
    esac
  done
}

load_config() {
  LOOP_UNTIL=""
  if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi
}

detect_dnf() {
  if command -v dnf >/dev/null 2>&1; then
    DNF="dnf"
  else
    fail "dnf command not found"
  fi
}

install_upgrade_plugin_if_needed() {
  local msg_fn="${1:-log}"
  "$msg_fn" "Ensuring dnf system-upgrade support is installed"

  if dnf system-upgrade --help >/dev/null 2>&1; then
    "$msg_fn" "dnf system-upgrade already available"
    return 0
  fi

  run_dnf_logged "$msg_fn" install -y dnf-plugin-system-upgrade || \
    fail "Could not install dnf-plugin-system-upgrade"
}

current_release() {
  rpm -E %fedora 2>/dev/null || true
}

detect_target_release() {
  local current
  current="$(current_release)"

  if [[ -z "$current" || ! "$current" =~ ^[0-9]+$ ]]; then
    fail "Could not detect current Fedora release"
  fi

  TARGET_RELEASE=$((current + 1))
}

upgrade_available() {
  local target="$1"
  dnf --releasever="${target}" -q repo info fedora >/dev/null 2>&1
}

run_dnf_logged() {
  local msg_fn="${1:-log}"
  shift
  "$msg_fn" "Running: dnf $*"
  if [[ -n "$CONSOLE_FD" ]]; then
    dnf "$@" 2>&1 | tee -a "$LOG_FILE" >&"${CONSOLE_FD}"
  else
    dnf "$@" 2>&1 | tee -a "$LOG_FILE"
  fi
}

grace_period() {
  rm -f "$CANCEL_FILE"

  console_log "Fedora upgrade: waiting ${GRACE_SECONDS}s after boot before starting"
  console_log "Cancel with: touch ${CANCEL_FILE}"
  console_log "             systemctl stop ${BOOT_SERVICE_NAME}.service"
  console_log "Or press any key on the primary console (tty1)"

  local remaining=$GRACE_SECONDS
  while (( remaining > 0 )); do
    if [[ -f "$CANCEL_FILE" ]]; then
      console_log "Upgrade cancelled (cancel file detected)"
      rm -f "$CANCEL_FILE"
      exit 0
    fi

    if [[ -n "$CONSOLE_FD" ]]; then
      if read -t 1 -n 1 <&3 &>/dev/null; then
        console_log "Upgrade cancelled (key pressed on console)"
        exit 0
      fi
    else
      sleep 1
    fi

    if (( remaining % 60 == 0 || remaining <= 10 )); then
      console_log "Upgrade begins in ${remaining} seconds..."
    fi
    ((remaining--)) || true
  done

  console_log "Grace period ended; starting upgrade checks"
}

write_config() {
  if [[ -n "$LOOP_UNTIL_INSTALL" ]]; then
    cat >"$CONFIG_FILE" <<EOF
# Written by ${SERVICE_NAME} install
LOOP_UNTIL=${LOOP_UNTIL_INSTALL}
EOF
    echo "Configured loop-until Fedora ${LOOP_UNTIL_INSTALL} in ${CONFIG_FILE}"
  elif [[ -f "$CONFIG_FILE" ]]; then
    rm -f "$CONFIG_FILE"
    echo "Removed ${CONFIG_FILE} (timer-only mode)"
  fi
}

install_timer_unit() {
  cat >"/etc/systemd/system/${SERVICE_NAME}.service" <<EOF
[Unit]
Description=Fedora overnight release upgrade check
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=${INSTALL_PATH} run
EOF

  cat >"/etc/systemd/system/${SERVICE_NAME}.timer" <<EOF
[Unit]
Description=Run Fedora overnight upgrade check daily at ${SCHEDULE}

[Timer]
OnCalendar=*-*-* ${SCHEDULE}:00
Persistent=true

[Install]
WantedBy=timers.target
EOF

  systemctl daemon-reload
  systemctl enable --now "${SERVICE_NAME}.timer"
  systemctl disable --now "${BOOT_SERVICE_NAME}.service" 2>/dev/null || true

  echo "Enabled ${SERVICE_NAME}.timer (daily at ${SCHEDULE})"
}

install_boot_unit() {
  cat >"/etc/systemd/system/${BOOT_SERVICE_NAME}.service" <<EOF
[Unit]
Description=Fedora incremental release upgrade (loop until target)
Wants=network-online.target
After=network-online.target multi-user.target
ConditionPathExists=${CONFIG_FILE}

[Service]
Type=oneshot
ExecStart=${INSTALL_PATH} run-loop

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable --now "${BOOT_SERVICE_NAME}.service"
  systemctl disable --now "${SERVICE_NAME}.timer" 2>/dev/null || true

  echo "Enabled ${BOOT_SERVICE_NAME}.service (runs on boot)"
}

install_systemd_unit() {
  parse_install_args "$@"
  require_root

  install -Dm755 "${SCRIPT_PATH}" "${INSTALL_PATH}"
  write_config

  if [[ -n "$LOOP_UNTIL_INSTALL" ]]; then
    install_boot_unit
  else
    install_timer_unit
  fi

  echo "Installed ${INSTALL_PATH}"
  echo
  echo "Check status:"
  if [[ -n "$LOOP_UNTIL_INSTALL" ]]; then
    echo "  systemctl status ${BOOT_SERVICE_NAME}.service"
    echo "  tail -f ${LOG_FILE}"
    echo
    echo "Disable boot-time upgrades:"
    echo "  systemctl disable --now ${BOOT_SERVICE_NAME}.service"
  else
    echo "  systemctl status ${SERVICE_NAME}.timer"
    echo
    echo "Disable automatic checks:"
    echo "  systemctl disable --now ${SERVICE_NAME}.timer"
  fi
}

stage_and_reboot_upgrade() {
  local current="$1"
  local target="$2"
  local msg_fn="${3:-log}"

  "$msg_fn" "Starting Fedora upgrade on ${HOST}"
  "$msg_fn" "Current Fedora release: ${current}"
  "$msg_fn" "Target Fedora release: ${target}"

  notify "info" \
    "Fedora upgrade started" \
    "Current release: ${current}; target release: ${target}"

  "$msg_fn" "Refreshing and upgrading current system"
  run_dnf_logged "$msg_fn" upgrade --refresh -y || fail "Current-system dnf upgrade failed"

  install_upgrade_plugin_if_needed "$msg_fn"

  "$msg_fn" "Downloading Fedora ${target} system upgrade packages"
  notify "info" \
    "Fedora upgrade download started" \
    "Downloading/staging Fedora ${target} upgrade packages."

  run_dnf_logged "$msg_fn" system-upgrade download --refresh --releasever="${target}" -y || \
    fail "dnf system-upgrade download failed for Fedora ${target}"

  "$msg_fn" "Download/staging completed successfully"

  notify "warning" \
    "Rebooting for Fedora upgrade" \
    "This host is rebooting to perform an offline system upgrade.

Current release: Fedora ${current}
Target release after upgrade: Fedora ${target}"

  "$msg_fn" "Rebooting into offline upgrade (Fedora ${current} -> ${target})"
  dnf system-upgrade reboot
}

run_upgrade() {
  require_root
  detect_dnf
  detect_target_release

  if ! upgrade_available "${TARGET_RELEASE}"; then
    exit 0
  fi

  local current
  current="$(current_release)"

  stage_and_reboot_upgrade "$current" "$TARGET_RELEASE" log
}

run_loop() {
  require_root
  console_open
  detect_dnf
  load_config

  if [[ -z "$LOOP_UNTIL" || ! "$LOOP_UNTIL" =~ ^[0-9]+$ ]]; then
    fail "LOOP_UNTIL not configured in ${CONFIG_FILE}"
  fi

  local current
  current="$(current_release)"

  if [[ -z "$current" || ! "$current" =~ ^[0-9]+$ ]]; then
    fail "Could not detect current Fedora release"
  fi

  console_log "Fedora loop upgrade: current release ${current}, loop-until ${LOOP_UNTIL}"

  if (( current >= LOOP_UNTIL )); then
    console_log "Already at Fedora ${current} (target: ${LOOP_UNTIL}). Nothing to do."
    exit 0
  fi

  grace_period

  TARGET_RELEASE=$((current + 1))
  console_log "Next incremental target: Fedora ${TARGET_RELEASE}"

  if ! upgrade_available "${TARGET_RELEASE}"; then
    console_log "Fedora ${TARGET_RELEASE} is not yet available. Will retry on next boot."
    exit 0
  fi

  stage_and_reboot_upgrade "$current" "$TARGET_RELEASE" console_log
}

test_notify() {
  if ! command -v apprise >/dev/null 2>&1; then
    echo "apprise command not found" >&2
    exit 1
  fi

  if notify "info" \
    "Fedora upgrade notification test" \
    "This is a test notification from ${SERVICE_NAME}."; then
    echo "Notification sent."
  else
    echo "Failed to send notification." >&2
    exit 1
  fi
}

case "${1:-}" in
  install)
    install_systemd_unit "${@:2}"
    ;;
  run)
    run_upgrade
    ;;
  run-loop)
    run_loop
    ;;
  notify)
    test_notify
    ;;
  "")
    usage
    ;;
  *)
    usage
    ;;
esac
